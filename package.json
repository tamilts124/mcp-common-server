{
  "name": "mcp-common-server",
  "description": "Universal MCP server — multi-root, HTTP+SSE + stdio transport, exec/pipeline support, zero deps for core tools, Playwright for browser automation",
  "main": "server-http.js",
  "bin": {
    "mcp-file-server": "./server-http.js",
    "mcp-file-server-stdio": "./server-stdio.js"
  },
  "scripts": {
    "start": "node server-http.js",
    "start:stdio": "node server-stdio.js",
    "test": "node test/run-tests.js",
    "test:browser": "node test/browser-tests.js",
    "test:browser-part2": "node test/browser-tests-part2.js",
    "test:browser-edge": "node test/browser-edge-tests.js",
    "test:browser-dialog-queue": "node test/browser-dialog-queue-tests.js",
    "test:browser-viewport": "node test/browser-set-viewport-tests.js",
    "test:browser-frame-evaluate": "node test/browser-frame-evaluate-tests.js",
    "test:gzip": "node test/gzip-tests.js",
    "test:brotli": "node test/brotli-tests.js",
    "test:checksum-verify": "node test/checksum-verify-tests.js",
    "test:stress": "node test/stress-tests.js",
    "test:disk-usage": "node test/disk-usage-tests.js",
    "test:scan-dependency-licenses": "node test/scan-dependency-licenses-tests.js",
    "test:browser-replay-actions": "node test/browser-replay-actions-tests.js",
    "test:case-sensitive-imports": "node test/find-case-sensitive-import-mismatches-tests.js",
    "test:cors-misconfig": "node test/scan-cors-misconfig-tests.js",
    "test:dangerous-patterns": "node test/scan-dangerous-code-patterns-tests.js",
    "test:find-duplicate-yaml-keys": "node test/find-duplicate-yaml-keys-tests.js",
    "test:find-unsafe-regex": "node test/find-unsafe-regex-tests.js",
    "test:find-unpinned-actions": "node test/find-unpinned-github-actions-tests.js",
    "test:npm-lifecycle-scripts": "node test/scan-npm-lifecycle-scripts-tests.js",
    "test:semver-range-strictness": "node test/check-semver-range-strictness-tests.js",
    "test:empty-catch-blocks": "node test/find-empty-catch-blocks-tests.js",
    "test:sync-fs-in-async": "node test/find-sync-fs-in-async-context-tests.js",
    "test:hardcoded-credentials-config": "node test/find-hardcoded-credentials-in-config-tests.js",
    "test:hardcoded-ports": "node test/find-hardcoded-ports-tests.js",
    "test:dangling-promises": "node test/find-dangling-promises-tests.js",
    "test:insecure-random": "node test/find-insecure-random-usage-tests.js",
    "test:unbounded-recursion": "node test/find-unbounded-recursion-tests.js",
    "test:open-redirect": "node test/find-open-redirect-risks-tests.js",
    "test:blocking-child-process": "node test/find-blocking-child-process-calls-tests.js",
    "test:missing-json-content-type": "node test/find-missing-json-response-content-type-tests.js",
    "test:unhandled-express-error": "node test/find-unhandled-express-error-middleware-tests.js",
    "test:promise-all-without-catch": "node test/find-promise-all-without-catch-tests.js",
    "test:unbounded-object-growth": "node test/find-unbounded-object-growth-tests.js",
    "test:missing-null-checks-regex-exec": "node test/find-missing-null-checks-after-regex-exec-tests.js",
    "test:regex-dos-route-params": "node test/find-regex-dos-route-params-tests.js",
    "test:test-flakiness-risk": "node test/check-test-flakiness-risk-tests.js",
    "test:missing-csp-header": "node test/check-missing-csp-header-tests.js",
    "test:missing-sort-comparator": "node test/find-missing-sort-comparator-tests.js",
    "test:req-body-mass-assignment": "node test/find-req-body-mass-assignment-tests.js",
    "test:prototype-pollution-risk": "node test/find-prototype-pollution-risk-tests.js"
