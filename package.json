{
  "name": "mcp-common-server",
  "version": "3.2.0",
  "description": "Universal MCP server — multi-root, HTTP+SSE + stdio transport, exec/pipeline support, zero dependencies",
  "main": "server-http.js",
  "bin": {
    "mcp-file-server": "./server-http.js",
    "mcp-file-server-stdio": "./server-stdio.js"
  },
  "scripts": {
    "start": "node server-http.js",
    "start:stdio": "node server-stdio.js",
    "test": "node test/run-tests.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "playwright": "^1.61.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
