# ------------------------------------------------------------------------------
# MCP Common Server Configuration Template (.env.example)
# Rename this file to '.env' and edit the parameters for your local setup.
# ------------------------------------------------------------------------------

# The Port number the local server will listen on
PORT=3000

# Comma-separated list of workspace root directories to jail the server to.
# Example: D:/projects/project-one,D:/projects/project-two
# Each directory will be mapped to a lowercase alias prefix in path resolution.
MCP_ROOTS=

# Legacy configuration for a single root directory (ignored if MCP_ROOTS is set)
# MCP_ROOT_DIR=

# Security Token (Authorization Bearer). Unset or leave blank for open local access.
# If set, requests must include the header: "Authorization: Bearer <your_token>"
# MCP_AUTH_TOKEN=

# Read-Only Mode: Set to 'true' to completely disable modifying files and commands
MCP_READ_ONLY=false

# Shell Execution Access: Set to 'true' to allow run_command and background execution
MCP_ALLOW_EXEC=false

# Maximum execution timeout in seconds for synchronous run_command actions
MCP_CMD_TIMEOUT=60

# Comma-separated directory/file prefixes to ignore in file scans and search listings
MCP_IGNORE=node_modules,.git,__pycache__,.nyc_output,dist,build,.venv,venv
